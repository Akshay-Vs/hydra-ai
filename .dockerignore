tests/
test/
*.test.js
*.test.py
*.spec.js
*.spec.py

# Development and CI files
.github
.gitlab-ci.yml
.travis.yml
.circleci
Makefile
docker-compose*.yml
*.dockerfile
Dockerfile.dev

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

