generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User management (Both Human and AI Agent)
model User {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String?  @unique // Optional for AI agents
  displayName String?
  avatarUrl   String?
  bio         String?
  type        UserType @default(HUMAN)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Authentication (for humans)
  passwordHash  String?
  emailVerified Boolean @default(false)

  // AI Agent specific fields
  aiConfig AIAgentConfig?

  // User preferences
  preferences UserPreferences?

  // Relationships - Every user MUST be in at least one organization
  organizationMemberships OrganizationMember[]
  sentInvitations         OrganizationInvitation[] @relation("InvitationSender")
  receivedInvitations     OrganizationInvitation[] @relation("InvitationReceiver")

  @@map("users")
}

model AIAgentConfig {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  model        String
  provider     String
  version      String?
  systemPrompt String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_agent_configs")
}

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // UI preferences
  theme    String @default("light") // light, dark, system
  language String @default("en")
  timezone String @default("UTC")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// Organization management
model Organization {
  id          String   @id @default(cuid())
  name        String
  description String?
  avatarUrl   String?
  website     String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  members     OrganizationMember[]
  invitations OrganizationInvitation[]
  roles       OrganizationRole[]

  @@map("organizations")
}

model OrganizationMember {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  roleId         String // Direct role assignment - simplified
  title          String? // Job title
  department     String?
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime         @default(now())
  leftAt         DateTime?

  // Optional role override fields
  grantedBy     String? // User ID who granted this role
  roleExpiresAt DateTime? // Optional role expiration

  // Relationships
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         OrganizationRole @relation(fields: [roleId], references: [id])

  @@unique([userId, organizationId])
  @@map("organization_members")
}

model OrganizationInvitation {
  id             String           @id @default(cuid())
  organizationId String
  senderId       String
  receiverId     String
  proposedRoleId String // Single role ID instead of array
  title          String? // Proposed job title
  department     String?
  status         InvitationStatus @default(PENDING)
  message        String?
  expiresAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relationships
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sender       User         @relation("InvitationSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User         @relation("InvitationReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([organizationId, receiverId])
  @@map("organization_invitations")
}

// Simplified Organization Role System
model OrganizationRole {
  id             String         @id @default(cuid())
  organizationId String
  name           String // Role name within the organization
  description    String?
  permissions    RolePermission @relation(fields: [rolePermissionId], references: [id])
  isDefault      Boolean        @default(false)
  isSystem       Boolean        @default(false)
  level          Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relationships
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members          OrganizationMember[]
  rolePermissionId String

  @@unique([organizationId, name])
  @@map("organization_roles")
}

model RolePermission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "org.create", "user.read", "logs.write"
  resource    String // e.g., "organization", "user", "logs"
  action      String // e.g., "create", "read", "update", "delete"
  description String?
  createdAt   DateTime @default(now())

  // Relationships
  OrganizationRole OrganizationRole[]

  @@map("permissions")
}

// Enums
enum UserType {
  HUMAN
  AI_AGENT
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  LEFT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}
