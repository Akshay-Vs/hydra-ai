{
  "name": "@hydra/ui",
  "version": "0.1.0",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "./styles.css": "./dist/index.css",
    "./*": {
      "import": "./dist/components/ui/*.mjs",
      "types": "./dist/components/ui/*.d.ts"
    },
    "./libs/*": {
      "import": "./dist/lib/*.mjs",
      "types": "./dist/lib/*.d.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "dev": "tsc watch.ts --outDir ./dist && node ./dist/watch.js",
    "type-check": "tsc --noEmit",
    "build:tailwind": "pnpm dlx @tailwindcss/cli -i src/styles.css -o dist/index.css"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@hydra/typescript-config": "workspace:*",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.539.0",
    "recharts": "2.15.4",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.6"
  }
}
